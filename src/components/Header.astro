---
import { NAV, SITE } from '../data/site';
---

<header class="sticky top-0 z-50 border-b-2 border-ink bg-cream/90 backdrop-blur">
  <div class="container-x flex items-center justify-between gap-4 py-3">
    <a href="/" class="flex items-center gap-3" aria-label="Accueil Chicken Ben's">
      <img
        src="/images/logo.png"
        alt="Logo Chicken Ben's Restaurant"
        width="56"
        height="56"
        class="h-12 w-12 sm:h-14 sm:w-14"
        loading="eager"
      />
      <span class="hidden flex-col leading-tight sm:flex">
        <span class="font-heading text-lg text-ink">Chicken Ben's</span>
        <span class="font-body text-[10px] uppercase tracking-[0.2em] text-ink/60"
          >Colomiers · Toulouse</span
        >
      </span>
    </a>

    <nav aria-label="Menu principal" class="hidden items-center gap-1 lg:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-4 py-2 font-display text-sm uppercase tracking-wide text-ink/80 transition-colors hover:bg-ink hover:text-mustard"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`tel:${SITE.phone.replace(/\s/g, '')}`}
        class="hidden items-center gap-2 rounded-full border-2 border-ink px-4 py-2 font-display text-sm md:inline-flex"
        aria-label={`Appeler ${SITE.name}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        {SITE.phoneDisplay}
      </a>
      <a href={SITE.social.ubereats} target="_blank" rel="noopener" class="btn-primary !py-2 !px-4 !text-sm">
        Commander
      </a>

      <button
        id="nav-toggle"
        class="lg:hidden rounded-full border-2 border-ink p-2"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t-2 border-ink bg-cream lg:hidden">
    <nav aria-label="Menu mobile" class="container-x flex flex-col py-3">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-3 py-3 font-display text-base uppercase tracking-wide text-ink hover:bg-ink hover:text-mustard"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={`tel:${SITE.phone.replace(/\s/g, '')}`}
        class="mt-2 rounded-lg border-2 border-ink px-3 py-3 text-center font-display text-base uppercase tracking-wide"
      >
        📞 {SITE.phoneDisplay}
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', open ? 'false' : 'true');
  });
  document.querySelectorAll('#mobile-menu a').forEach((a) =>
    a.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>
