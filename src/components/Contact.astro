---
import { SITE } from '../data/site';
const mapsQuery = encodeURIComponent(
  `${SITE.address.street}, ${SITE.address.postal} ${SITE.address.city}`
);
---

<section id="contact" class="bg-cream py-20 sm:py-28">
  <div class="container-x">
    <div class="flex flex-col items-center text-center">
      <span class="section-eyebrow">Contact</span>
      <h2 class="section-title">On t'attend de pied ferme</h2>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-5">
      <!-- Infos -->
      <div class="lg:col-span-2">
        <div class="card h-full">
          <h3 class="font-heading text-2xl uppercase">Le restaurant</h3>
          <p class="mt-2 font-hand text-2xl text-rooster">Colomiers · 31770</p>

          <dl class="mt-6 space-y-5 text-ink/80">
            <div>
              <dt class="font-display text-xs uppercase tracking-widest text-ink/50">Adresse</dt>
              <dd class="mt-1 font-body text-base">
                {SITE.address.street}<br />{SITE.address.postal} {SITE.address.city}
              </dd>
            </div>
            <div>
              <dt class="font-display text-xs uppercase tracking-widest text-ink/50">Téléphone</dt>
              <dd class="mt-1">
                <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="font-body text-base hover:text-rooster">
                  {SITE.phoneDisplay}
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-display text-xs uppercase tracking-widest text-ink/50">Email</dt>
              <dd class="mt-1">
                <a href={`mailto:${SITE.email}`} class="font-body text-base hover:text-rooster">
                  {SITE.email}
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-display text-xs uppercase tracking-widest text-ink/50">Horaires</dt>
              <dd class="mt-1 font-body text-base">
                {SITE.openingHours.map((h) => (
                  <div class="flex justify-between gap-4 border-b border-ink/10 py-1">
                    <span>{h.days}</span>
                    <span class="font-semibold">{h.hours}</span>
                  </div>
                ))}
              </dd>
            </div>
            <div>
              <dt class="font-display text-xs uppercase tracking-widest text-ink/50">Moyens de paiement</dt>
              <dd class="mt-2 flex flex-wrap gap-2">
                {SITE.payments.map((p) => <span class="chip">{p}</span>)}
              </dd>
            </div>
          </dl>

          <a
            href={`https://www.google.com/maps/dir/?api=1&destination=${mapsQuery}`}
            target="_blank"
            rel="noopener"
            class="btn-primary mt-8 w-full justify-center"
          >
            Itinéraire Google Maps
          </a>
        </div>
      </div>

      <!-- Carte -->
      <div class="lg:col-span-3">
        <div class="poster h-full min-h-[400px] overflow-hidden !p-0">
          <iframe
            title={`Plan - ${SITE.name} Colomiers`}
            src={`https://maps.google.com/maps?q=${mapsQuery}&output=embed`}
            class="h-full w-full"
            style="min-height:400px;border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
