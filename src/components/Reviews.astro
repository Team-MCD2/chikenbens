---
import { REVIEWS, SITE } from '../data/site';
---

<section id="avis" class="relative bg-ink py-20 text-cream sm:py-28">
  <div class="container-x">
    <div class="flex flex-col items-center text-center">
      <span class="section-eyebrow !bg-mustard !text-ink">Avis clients</span>
      <h2 class="section-title !text-cream">Ils sont passés casser la graine</h2>
      <div class="mt-4 flex items-center gap-3 text-mustard">
        <div class="flex gap-1">
          {Array.from({ length: 5 }).map(() => (
            <svg class="h-6 w-6 fill-mustard" viewBox="0 0 20 20"><path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.3 2.8 1-5.9L1.4 7.7l5.9-.9z"/></svg>
          ))}
        </div>
        <span class="font-display text-xl text-cream">
          {SITE.rating.value} / 5 &middot; +{SITE.rating.count} avis
        </span>
      </div>
      <p class="mt-3 text-sm text-cream/60">
        Avis vérifiés sur Google, Uber Eats et Facebook.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        REVIEWS.map((r) => (
          <article class="group relative rounded-3xl border-2 border-cream/10 bg-ink-800 p-6 transition-all hover:border-mustard hover:-translate-y-1">
            <div class="flex items-center justify-between">
              <div class="flex gap-1 text-mustard">
                {Array.from({ length: r.rating }).map(() => (
                  <svg class="h-4 w-4 fill-mustard" viewBox="0 0 20 20"><path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.3 2.8 1-5.9L1.4 7.7l5.9-.9z"/></svg>
                ))}
              </div>
              <span class="chip !border-cream/20 !bg-ink-700 !text-cream/70">{r.source}</span>
            </div>

            <p class="mt-4 font-body text-cream/90">« {r.text} »</p>

            <footer class="mt-5 flex items-center gap-3 border-t border-cream/10 pt-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-mustard font-display text-ink">
                {r.author.charAt(0)}
              </div>
              <div>
                <p class="font-display text-sm uppercase">{r.author}</p>
                <p class="text-xs text-cream/60">{r.date}</p>
              </div>
            </footer>
          </article>
        ))
      }
    </div>

    <!-- CTA avis Google (tri par meilleures notes = avis positifs en premier) -->
    <div class="mt-14 flex flex-col items-center">
      <a
        href={SITE.social.googleReviews}
        target="_blank"
        rel="noopener"
        class="group inline-flex items-center gap-4 rounded-full border-2 border-cream bg-cream px-6 py-4 font-display text-sm uppercase tracking-wider text-ink shadow-pop-red transition-transform hover:-translate-y-1 hover:shadow-[8px_8px_0_0_#E63328] sm:text-base"
        aria-label="Voir tous les avis Google de Chicken Ben's"
      >
        <!-- Logo Google officiel (4 couleurs) -->
        <svg class="h-7 w-7 shrink-0" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3c-1.6 4.7-6.1 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3l5.7-5.7C33.9 6.1 29.2 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.4-.4-3.5z"/>
          <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15.1 19 12 24 12c3.1 0 5.9 1.2 8 3l5.7-5.7C33.9 6.1 29.2 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
          <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2c-2 1.4-4.5 2.4-7.2 2.4-5.2 0-9.6-3.3-11.3-7.9l-6.5 5C9.5 39.7 16.2 44 24 44z"/>
          <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.3-4.1 5.6l6.2 5.2C41.1 35.2 44 30 44 24c0-1.3-.1-2.4-.4-3.5z"/>
        </svg>
        <span class="flex flex-col items-start leading-tight">
          <span class="text-xs normal-case text-ink/60">Ils nous adorent sur</span>
          <span class="font-heading text-lg">Voir les avis Google</span>
        </span>
        <span
          class="flex h-9 w-9 items-center justify-center rounded-full bg-ink text-mustard transition-transform group-hover:translate-x-1"
          aria-hidden="true"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
      <p class="mt-3 text-xs text-cream/50">
        Avis triés par meilleure note · +{SITE.rating.count} clients satisfaits
      </p>
    </div>
  </div>
</section>
