---
import { SITE, NAV } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="bg-ink text-cream">
  <!-- haut -->
  <div class="container-x grid gap-10 py-16 md:grid-cols-12">
    <div class="md:col-span-4">
      <a href="/" class="flex items-center gap-3">
        <img src="/images/logo.png" alt="" width="64" height="64" class="h-14 w-14" />
        <span class="font-heading text-2xl uppercase">Chicken Ben's</span>
      </a>
      <p class="mt-4 font-body text-sm text-cream/70">
        Spécialiste du poulet frit frais & halal à Colomiers et Toulouse.
        Préparé à la main, servi avec le sourire.
      </p>
      <div class="mt-6 flex gap-3">
        <a href={SITE.social.facebook} aria-label="Facebook" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-cream/20 text-cream hover:bg-mustard hover:text-ink hover:border-mustard">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9V15h-2V12h2V9.8c0-2 1.2-3.1 3-3.1.9 0 1.8.2 1.8.2v2h-1c-1 0-1.3.6-1.3 1.3V12h2.3l-.4 3h-1.9v6.9A10 10 0 0 0 22 12z"/></svg>
        </a>
        <a href={SITE.social.instagram} aria-label="Instagram" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-cream/20 text-cream hover:bg-mustard hover:text-ink hover:border-mustard">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </a>
        <a href={SITE.social.ubereats} aria-label="Uber Eats" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-cream/20 text-cream hover:bg-mustard hover:text-ink hover:border-mustard">
          <span class="font-display text-xs">UE</span>
        </a>
      </div>
    </div>

    <div class="md:col-span-3">
      <p class="font-display text-sm uppercase text-mustard">Navigation</p>
      <ul class="mt-4 space-y-2 font-body text-sm">
        {NAV.map((i) => (
          <li><a href={i.href} class="text-cream/80 hover:text-mustard">{i.label}</a></li>
        ))}
        <li><a href="/mentions-legales" class="text-cream/80 hover:text-mustard">Mentions légales</a></li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <p class="font-display text-sm uppercase text-mustard">Le resto</p>
      <address class="mt-4 not-italic font-body text-sm text-cream/80">
        {SITE.address.street}<br />
        {SITE.address.postal} {SITE.address.city}<br />
        <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="hover:text-mustard">{SITE.phoneDisplay}</a><br />
        <a href={`mailto:${SITE.email}`} class="hover:text-mustard">{SITE.email}</a>
      </address>
    </div>

    <div class="md:col-span-2">
      <p class="font-display text-sm uppercase text-mustard">Horaires</p>
      <ul class="mt-4 space-y-1 font-body text-sm text-cream/80">
        {SITE.openingHours.map((h) => (
          <li>
            <span class="block text-cream">{h.days}</span>
            <span class="text-cream/60">{h.hours}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- bas -->
  <div class="border-t border-cream/10">
    <div class="container-x flex flex-col items-center justify-between gap-3 py-5 text-xs text-cream/60 md:flex-row">
      <p>&copy; {year} CHICKEN BEN'S 31 — Tous droits réservés.</p>
      <p class="flex flex-wrap items-center gap-4">
        <a href="/mentions-legales" class="hover:text-mustard">Mentions légales</a>
        <a href="/mentions-legales#confidentialite" class="hover:text-mustard">Confidentialité</a>
        <a href="/mentions-legales#cookies" class="hover:text-mustard">Cookies</a>
      </p>
      <p class="text-cream/40">SIRET 837 889 088 00014</p>
    </div>
  </div>
</footer>
